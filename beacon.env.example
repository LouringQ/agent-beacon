# beacon.env — 复制成 beacon.env,和脚本放一个目录,填好你自己的值。
# hook 子进程的环境变量取决于「谁启动了 agent」;Codex 不会把自己配置里的 env 传给
# hook。这个文件在脚本启动时读取,只填补【缺失】的变量,真实环境变量永远优先。
# 路径可用 BEACON_ENV_FILE 覆盖。

# ---- 必填 ----
PUSHCUT_KEY=REPLACE_WITH_YOUR_PUSHCUT_API_KEY
NTFY_TOPIC=REPLACE_WITH_A_LONG_RANDOM_SECRET_TOPIC
PUSHCUT_NOTIF=agent-beacon

# ---- 送达(Apple Watch 实测有效) ----
PUSHCUT_DEVICES=iPhone
PUSHCUT_SOUND=default
PUSHCUT_TIME_SENSITIVE=1

# ---- 网络(国内走代理才需要) ----
#HTTPS_PROXY=http://127.0.0.1:7890
#NTFY_TOKEN=

# ---- 审批行为 ----
BEACON_APPROVE_WAIT=240
BEACON_APPROVE_TIMEOUT_DECISION=ask
# 1=只有 dangerous/sensitive 才上手表,safe 静默走 NONDANGER_DECISION;0=所有事件都上手表
BEACON_DANGER_ONLY=1
BEACON_NONDANGER_DECISION=ask
# sensitive 路径(.env/.ssh/CI 配置……)是否和 dangerous 一样强制上手表
BEACON_ESCALATE_SENSITIVE=1
# 等待期间每隔 N 秒重发一次通知,0=只发一次
BEACON_RENOTIFY_INTERVAL=120
# 超时没人理,退回终端前补一条「你错过了」提醒
BEACON_MISSED_ALERT=1

# ---- Auto-CLI:iPhone 专注自动放行(核心功能) ----
# 触发列表:显示名或 modeIdentifier,命中其一即可
AUTO_FOCUS_NAMES=Auto-CLI,com.apple.donotdisturb.mode.heartfill,com.apple.focus.gaming,com.apple.sleep.sleep-mode,com.apple.donotdisturb.mode.default
# 自动驾驶下遇到 dangerous 操作怎么办:allow(全自动)/ notify(仍推手表)/ deny(直接拒绝)
BEACON_AUTO_FOCUS_DANGER=allow
# 本地镜像旗标(给没有「完全磁盘访问」权限的宿主兜底,也是菜单栏 App 手动开关走的通道)
#BEACON_AUTO_FOCUS_FLAG=~/.agent-beacon/focus-mirror.flag
BEACON_AUTO_FOCUS_MAX_AGE_MIN=10

# ---- 终端强制确认路径(Claude Code 自己拦的,hook 压不住,只提醒不审批) ----
#BEACON_TERMINAL_FORCED_PATHS=.claude\settings.json,.claude/settings.json,.claude\hooks,.claude/hooks,.claude\CLAUDE.md,.claude/CLAUDE.md

# ---- 危险清单自定义 ----
#BEACON_DANGER_EXTRA=
#BEACON_DANGER_REGEX=

# ---- 其它 ----
BEACON_SHOW_CWD=1
BEACON_UNIQUE_TOPIC=1
BEACON_TERMINAL_BUTTON=1
# 本地状态目录(SQLite 审批日志 + 旗标文件)
#BEACON_HOME=~/.agent-beacon
# Dashboard 端口
#BEACON_DASHBOARD_PORT=8787
